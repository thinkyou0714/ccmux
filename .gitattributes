# Line-ending governance — ccmux (TS, WSL2/Linux-first, dev on Windows).
# All text normalized to LF in the working tree so .sh hooks/scripts and
# committed blobs stay LF across Windows checkouts (CRLF breaks bash on Linux).
* text=auto eol=lf

*.ts    text eol=lf
*.js    text eol=lf
*.mjs   text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.md    text eol=lf
*.sh    text eol=lf

# Binary (never normalize)
*.png   binary
*.jpg   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.pdf   binary
