{
  "name": "ccmux",
  "version": "0.1.0",
  "description": "Claude Code Multiplexer — Zellij × git worktree × n8n × Obsidian",
  "type": "module",
  "bin": {
    "ccmux": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "check": "npm run typecheck && npm run lint && npm run build && npm run test",
    "prepublishOnly": "npm run check"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "chalk": "^5.3.0",
    "commander": "^15.0.0",
    "execa": "^9.3.0",
    "ora": "^9.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.19",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^10.5.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
