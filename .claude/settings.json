{
  "permissions": {
    "allow": [
      "Bash(npm run build)",
      "Bash(npm run dev)",
      "Bash(npm run test)",
      "Bash(npm run lint)",
      "Bash(npm run typecheck)",
      "Bash(git status)",
      "Bash(git log)",
      "Bash(git diff)",
      "Bash(git branch)"
    ],
    "deny": [
      "Bash(rm -rf)",
      "Bash(rm -rf *)",
      "Bash(rm -fr)",
      "Bash(rm -fr *)",
      "Bash(git push --force)",
      "Bash(git push --force *)",
      "Bash(git push -f)",
      "Bash(git push -f *)",
      "Bash(git reset --hard)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f)",
      "Bash(git clean -f *)",
      "Bash(git clean -fd)",
      "Bash(git clean -fd *)",
      "Bash(git clean -fdx)",
      "Bash(git clean -fdx *)",
      "Bash(git clean -xdf)",
      "Bash(git clean -xdf *)",
      "Bash(git branch -D *)",
      "Bash(git branch -d *)",
      "Bash(git commit --no-verify *)",
      "Bash(git commit -n *)",
      "Bash(git push --no-verify *)",
      "Bash(git merge --no-verify *)"
    ]
  }
}
